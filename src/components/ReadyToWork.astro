---
import { client } from '../client.config.js'
---

<!-- Ready to Work Together Section -->
<section style="padding: 10rem 1.5rem; background: #fafaf8; position: relative">
  <div style="max-width: 1200px; margin: 0 auto; background: #1a2e26; border-radius: 40px; min-height: 500px; position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: center; padding: 6rem">
    <!-- Background Image with Strong Overlay -->
    <div style="position: absolute; inset: 0; z-index: 1">
      <img src="https://images.unsplash.com/photo-1558904541-efa843a96f01?auto=format&fit=crop&q=80&w=1200" style="width: 100%; height: 100%; object-fit: cover" alt="Texture" />
      <div style="position: absolute; inset: 0; background: rgba(26, 46, 38, 0.85); background: linear-gradient(135deg, rgba(26, 46, 38, 0.95) 0%, rgba(26, 46, 38, 0.7) 100%)"></div>
    </div>

    <div style="position: relative; z-index: 2; max-width: 800px">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2.5rem">
        <div style="width: 60px; height: 1px; background: #e0a526"></div>
        <span style="color: #e0a526; font-weight: 800; text-transform: uppercase; letter-spacing: 0.2em; font-size: 0.9rem">Ready to Work Together?</span>
      </div>
      
      <h2 style="font-size: 4rem; color: #fff; font-weight: 900; line-height: 1; margin: 0 0 2rem 0; letter-spacing: -0.02em">
        Let's grow your dream <br/>
        <span style="color: #e0a526">landscape</span> together.
      </h2>
      
      <p style="color: rgba(255,255,255,0.8); font-size: 1.25rem; line-height: 1.6; margin: 0 0 4rem 0; max-width: 600px">
        Contact us today to schedule your free on-site estimate. Our team of experts is ready to bring your vision to life.
      </p>
      
      <div style="display: flex; align-items: center; gap: 3rem; flex-wrap: wrap">
        <a href="/contact" style="background: #e0a526; color: #fff; padding: 1.5rem 3rem; border-radius: 100px; font-weight: 800; text-decoration: none; font-size: 1.2rem; box-shadow: 0 15px 30px rgba(224, 165, 38, 0.4); transition: all 0.3s ease; display: inline-block">
          Get A Free Estimate
        </a>
        
        <div style="display: flex; align-items: center; gap: 1.5rem">
          <div style="width: 60px; height: 60px; background: rgba(255,255,255,0.05); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; border: 1px solid rgba(255,255,255,0.1)">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <p style="color: rgba(255,255,255,0.5); font-size: 1rem; margin: 0">Have Questions?</p>
            <a href={`tel:${client.phone}`} style="color: #fff; font-weight: 800; font-size: 1.4rem; margin: 0; text-decoration: none; transition: color 0.3s">{client.phone}</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Large Watermark Logo in background -->
    <div style="position: absolute; right: -5%; bottom: -10%; z-index: 1; opacity: 0.05; pointer-events: none">
      <svg width="600" height="600" viewBox="0 0 24 24" fill="#fff">
        <path d="M17.67 7c-.79-1.28-2.3-2-4-2-3.31 0-6 2.69-6 6 0 2.21 1.2 4.15 3 5.19V20h2v-3.13c.32.08.65.13 1 .13 3.31 0 6-2.69 6-6 0-1.7-.68-3.21-1.78-4.27l1.45-1.45L17.67 7z"/>
      </svg>
    </div>
  </div>
</section>

---
import Layout from "../layouts/Layout.astro";
import { client } from "../client.config.js";

let services = [];
let testimonials = [];
try {
  const [s, t] = await Promise.all([
    fetch(
      `${client.cmsUrl}/api/services?where[tenant.slug][equals]=${client.tenantSlug}&limit=6`,
    ),
    fetch(
      `${client.cmsUrl}/api/testimonials?where[tenant.slug][equals]=${client.tenantSlug}&limit=3`,
    ),
  ]);
  services = (await s.json()).docs || [];
  testimonials = (await t.json()).docs || [];
} catch {}

const displayServices = services.length
  ? services
  : client.services.map((s: string) => ({
      title: s,
      description: `Professional ${s.toLowerCase()} services in ${client.city}.`,
    }));

import ServiceSection from "../components/ServiceSection.astro";

const primary = client.primaryColor || "#2d5a3d";
---

<Layout title="Home" description={client.tagline}>
  <!-- Vertical Slider Hero -->
  <section
    id="hero-slider"
    style="position:relative;height:85vh;overflow:hidden;background:#000"
  >
    <div
      id="slider-wrapper"
      style="height:100%;transition:transform 0.8s cubic-bezier(0.65, 0, 0.35, 1);display:flex;flex-direction:column"
    >
      <!-- Slide 1 -->
      <div
        class="slide"
        style="height:100%;flex-shrink:0;position:relative;background:url('/hero-1.png') center/cover no-repeat"
      >
        <div
          style="position:absolute;inset:0;background:linear-gradient(to right, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 60%)"
        >
        </div>
        <div
          class="container"
          style="position:relative;height:100%;display:flex;flex-direction:column;justify-content:center;padding:0 1.5rem;color:#fff;z-index:2"
        >
          <span
            style="color:#81c784;font-weight:600;text-transform:uppercase;letter-spacing:2px;margin-bottom:1rem;display:block"
            >Hassle-free garden transformations</span
          >
          <h1
            style="font-size:clamp(2.5rem,8vw,4.5rem);font-weight:900;margin:0 0 1.5rem;line-height:1.1;max-width:800px"
          >
            Make dream <br />
            <span style="color:#4caf50">gardening</span>
          </h1>
          <div style="display:flex;gap:1.5rem">
            <a
              href="/contact"
              style={`background:${primary};color:#fff;padding:1rem 2.5rem;border-radius:5px;font-weight:700;font-size:1.1rem`}
              >Get Free Quote</a
            >
          </div>
        </div>
      </div>

      <!-- Slide 2 -->
      <div
        class="slide"
        style="height:100%;flex-shrink:0;position:relative;background:url('/hero-2.png') center/cover no-repeat"
      >
        <div
          style="position:absolute;inset:0;background:linear-gradient(to right, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 60%)"
        >
        </div>
        <div
          class="container"
          style="position:relative;height:100%;display:flex;flex-direction:column;justify-content:center;padding:0 1.5rem;color:#fff;z-index:2"
        >
          <span
            style="color:#81c784;font-weight:600;text-transform:uppercase;letter-spacing:2px;margin-bottom:1rem;display:block"
            >Professional Landscaping</span
          >
          <h1
            style="font-size:clamp(2.5rem,8vw,4.5rem);font-weight:900;margin:0 0 1.5rem;line-height:1.1;max-width:800px"
          >
            Luxury outdoor <br />
            <span style="color:#4caf50">living spaces</span>
          </h1>
          <div style="display:flex;gap:1.5rem">
            <a
              href="/contact"
              style={`background:${primary};color:#fff;padding:1rem 2.5rem;border-radius:5px;font-weight:700;font-size:1.1rem`}
              >Our Projects</a
            >
          </div>
        </div>
      </div>

      <!-- Slide 3 -->
      <div
        class="slide"
        style="height:100%;flex-shrink:0;position:relative;background:url('/hero-3.png') center/cover no-repeat"
      >
        <div
          style="position:absolute;inset:0;background:linear-gradient(to right, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 60%)"
        >
        </div>
        <div
          class="container"
          style="position:relative;height:100%;display:flex;flex-direction:column;justify-content:center;padding:0 1.5rem;color:#fff;z-index:2"
        >
          <span
            style="color:#81c784;font-weight:600;text-transform:uppercase;letter-spacing:2px;margin-bottom:1rem;display:block"
            >Expert Garden Care</span
          >
          <h1
            style="font-size:clamp(2.5rem,8vw,4.5rem);font-weight:900;margin:0 0 1.5rem;line-height:1.1;max-width:800px"
          >
            Precision lawn <br />
            <span style="color:#4caf50">maintenance</span>
          </h1>
          <div style="display:flex;gap:1.5rem">
            <a
              href="/contact"
              style={`background:${primary};color:#fff;padding:1rem 2.5rem;border-radius:5px;font-weight:700;font-size:1.1rem`}
              >Contact Us</a
            >
          </div>
        </div>
      </div>
    </div>

    <!-- Slider Navigation Dots -->
    <div
      style="position:absolute;right:2rem;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:1rem;z-index:10"
    >
      <button
        class="dot active"
        data-index="0"
        style="width:12px;height:12px;border-radius:50%;background:#fff;border:none;cursor:pointer;opacity:0.5;transition:0.3s"
      ></button>
      <button
        class="dot"
        data-index="1"
        style="width:12px;height:12px;border-radius:50%;background:#fff;border:none;cursor:pointer;opacity:0.5;transition:0.3s"
      ></button>
      <button
        class="dot"
        data-index="2"
        style="width:12px;height:12px;border-radius:50%;background:#fff;border:none;cursor:pointer;opacity:0.5;transition:0.3s"
      ></button>
    </div>

    <style>
      .dot.active {
        opacity: 1;
        transform: scale(1.3);
        background: #4caf50 !important;
      }

      /* Reveal Animations */
      .slide .container > * {
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.8s cubic-bezier(0.2, 1, 0.3, 1);
      }

      .slide.active .container > * {
        opacity: 1;
        transform: translateY(0);
      }

      .slide.active .container span {
        transition-delay: 0.2s;
      }
      .slide.active .container h1 {
        transition-delay: 0.4s;
      }
      .slide.active .container div {
        transition-delay: 0.6s;
      }
    </style>

    <script>
      let currentIndex = 0;
      const slides = document.querySelectorAll(".slide");
      const wrapper = document.getElementById("slider-wrapper");
      const dots = document.querySelectorAll(".dot");
      const totalSlides = slides.length;

      function goToSlide(index: number) {
        currentIndex = index;
        if (wrapper) {
          wrapper.style.transform = `translateY(-${currentIndex * 100}%)`;
        }

        // Handle active class for reveal animation
        slides.forEach((slide, i) => {
          slide.classList.toggle("active", i === currentIndex);
        });

        dots.forEach((dot, i) => {
          dot.classList.toggle("active", i === currentIndex);
        });
      }

      // Initialize first slide as active
      slides[0].classList.add("active");

      function nextSlide() {
        currentIndex = (currentIndex + 1) % totalSlides;
        goToSlide(currentIndex);
      }

      let interval = setInterval(nextSlide, 5000);

      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const index = parseInt(dot.getAttribute("data-index") || "0");
          goToSlide(index);
          clearInterval(interval);
          interval = setInterval(nextSlide, 5000);
        });
      });
    </script>
  </section>
  <!-- Gold Marquee Section -->
  <section
    style="background:#e0a526; padding:0.8rem 0; overflow:hidden; border-bottom:1px solid rgba(0,0,0,0.1)"
  >
    <div
      class="marquee-container"
      style="display:flex; white-space:nowrap; width:max-content; animation: marquee-scroll 30s linear infinite"
    >
      {
        Array(4)
          .fill(0)
          .map(() => (
            <div style="display:flex; align-items:center; gap:2.5rem; padding-right:2.5rem">
              {[
                " Licensed & Insured",
                " Free Estimates",
                " Same Day Service",
                " 5-Star Rated",
                " Satisfaction Guaranteed",
              ].map((benefit) => (
                <span style="color:#fff; font-weight:700; font-size:1.1rem; display:flex; align-items:center; gap:0.5rem">
                  <span style="font-size:1.5rem">✻</span> {benefit}
                </span>
              ))}
            </div>
          ))
      }
    </div>
  </section>

  <style>
    @keyframes marquee-scroll {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(-50%);
      }
    }
  </style>

  <ServiceSection services={displayServices} />

  <!-- Premium Why Choose Us Section -->
  <section style="background:#fcfaf4; padding:8rem 1.5rem 10rem; position:relative; overflow:hidden">
    <!-- Floating Leaf Animation -->
    <div style="position:absolute; top:15%; left:8%; width:100px; z-index:1; animation: leaf-float 8s ease-in-out infinite">
      <img src="/leaf.png?v=2" alt="Leaf" style="width:100%; -webkit-mask-image: radial-gradient(circle, black 30%, transparent 70%); mask-image: radial-gradient(circle, black 30%, transparent 70%)" />
    </div>

    <!-- Floating Gold Circle -->
    <div style="position:absolute; top:35%; right:15%; width:20px; height:20px; border:2px solid #e0a526; border-radius:50%; opacity:0.3"></div>

    <div style="max-width:1200px; margin:0 auto; position:relative; z-index:2">
      <!-- Section Header -->
      <div style="text-align:center; margin-bottom:5rem">
        <div style="display:inline-flex; align-items:center; gap:0.5rem; margin-bottom:1rem">
          <div style={`width:24px; height:24px; background:${primary}; border-radius:50%; display:flex; align-items:center; justify-content:center`}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
          </div>
          <span style="color:#e0a526; font-size:0.85rem; font-weight:700; text-transform:uppercase; letter-spacing:2px">Our Features</span>
        </div>
        <h2 style="font-size:clamp(2.5rem, 5vw, 3.5rem); font-weight:800; color:#1a2e26; line-height:1.2; margin:0">
          Our Features that enrich <br/> your garden life
        </h2>
      </div>

      <!-- Features Row -->
      <div style="display:flex; flex-wrap:wrap; border-top:1px solid rgba(0,0,0,0.05); border-bottom:1px solid rgba(0,0,0,0.05); padding:4rem 0">
        {[
          { icon: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>', title: "Creative Landscaping", desc: "Grow with nature, bloom with purpose, live green every day." },
          { icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>', title: "Personalized Plant Solutions", desc: "Plant today, nurture tomorrow, and watch dreams blossom." },
          { icon: '<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>', title: "Sustainable Practices", desc: "Eco-friendly gardening methods supporting nature and growth." },
          { icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>', title: "Efficient Maintenance", desc: "Create green spaces that inspire peace, joy, and fresh living." },
        ].map((item, idx, arr) => (
          <div class="feature-item" style={`flex:1; min-width:250px; padding:0 2.5rem; ${idx < arr.length - 1 ? 'border-right:1px solid rgba(0,0,0,0.05)' : ''}; margin-bottom:2rem`}>
            <div style="margin-bottom:1.5rem">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#1a2e26" stroke-width="1.5" set:html={item.icon}></svg>
            </div>
            <h3 style="font-size:1.25rem; font-weight:800; color:#1a2e26; margin-bottom:1rem; line-height:1.3">{item.title}</h3>
            <p style="color:#6b7280; font-size:0.95rem; line-height:1.6">{item.desc}</p>
          </div>
        ))}
      </div>

      <!-- Quote Bar -->
      <div style="margin-top:6rem; display:flex; justify-content:center">
        <div style="background:#fff; padding:1.25rem 2.5rem; border-radius:100px; box-shadow:0 15px 40px rgba(0,0,0,0.05); display:flex; align-items:center; gap:3rem; flex-wrap:wrap">
          <p style="color:#6b7280; font-weight:500; margin:0">Harnessing the infinite power of the sun</p>
          <div style="display:flex; align-items:center; gap:1.5rem">
            <span style="font-weight:800; color:#1a2e26">Request A Quote</span>
            <a href={`tel:${client.phone}`} style="display:flex; align-items:center; gap:0.75rem; background:#e0a526; color:#fff; padding:0.6rem 1.5rem; border-radius:100px; text-decoration:none; font-weight:700">
              <div style="background:rgba(255,255,255,0.2); width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              {client.phone}
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Gardening Family Bottom Right -->
    <div style="position:absolute; bottom:0; right:0; width:500px; z-index:1; pointer-events:none">
      <img src="/gardening-family.png?v=2" alt="Gardening Family" style="width:100%; -webkit-mask-image: radial-gradient(circle at center, black 40%, transparent 95%); mask-image: radial-gradient(circle at center, black 40%, transparent 95%)" />
    </div>

    <style>
      .feature-item {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      }
      .feature-item.revealed {
        opacity: 1;
        transform: translateY(0);
      }
      @keyframes leaf-float {
        0%, 100% { transform: translate(0, 0) rotate(0); }
        50% { transform: translate(10px, -20px) rotate(15deg); }
      }
      @media (max-width: 1024px) {
        [style*="border-right"] { border-right: none !important; border-bottom: 1px solid rgba(0,0,0,0.05); }
        [style*="width:450px"], [style*="width:500px"] { width: 300px !important; }
        
        /* CTA Section Responsiveness */
        .cta-container { flex-direction: column !important; text-align: center; gap: 2rem !important; }
        .gardener-wrap { height: 450px !important; order: 2; margin-top: 2rem !important; }
        .gardener-img { position: relative !important; bottom: 0 !important; left: auto !important; margin: 0 auto; max-width: 450px !important; width: 100% !important; }
        .feature-grid { grid-template-columns: 1fr !important; gap: 1rem !important; display: inline-grid !important; text-align: left; }
        .cta-actions { justify-content: center !important; }
      }
    </style>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const featureItems = document.querySelectorAll('.feature-item');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              featureItems.forEach((item, i) => {
                setTimeout(() => {
                  item.classList.add('revealed');
                }, i * 200);
              });
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.2 });

        const section = document.querySelector('.feature-item')?.closest('section');
        if (section) observer.observe(section);
      });
    </script>
  </section>

  {
    testimonials.length > 0 && (
      <section style="padding:4rem 1.5rem">
        <div style="max-width:1200px;margin:0 auto">
          <h2 style="font-size:2rem;font-weight:700;text-align:center;margin-bottom:2.5rem">
            What Our Clients Say
          </h2>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem">
            {testimonials.map((t: any) => (
              <div style="padding:1.5rem;background:#f9fafb;border-radius:12px;border:1px solid #e5e7eb">
                <div style="color:#facc15;margin-bottom:0.75rem">★★★★★</div>
                <p style="color:#374151;font-style:italic;margin-bottom:1rem;line-height:1.7">
                  "{t.text || t.content}"
                </p>
                <p style="font-weight:700">{t.name || t.author}</p>
                {t.location && (
                  <p style="font-size:0.8rem;color:#6b7280">{t.location}</p>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- Premium Ready to Get Started (CTA) Section -->
  <section style="position:relative; background:#fff; overflow:hidden">
    <!-- Top White Space to bridge from previous section -->
    <div style="height:100px; background:#fff"></div>
    
    <div style="background:#1a2e26; position:relative; min-height:500px; padding:6rem 1.5rem">
      <!-- Foliage Overlay Background -->
      <div style="position:absolute; inset:0; background:url('/hero-1.jpg') center/cover no-repeat; opacity:0.15; filter: grayscale(1)"></div>
      
      <div class="cta-container" style="max-width:1200px; margin:0 auto; display:flex; align-items:flex-end; gap:4rem; position:relative; z-index:2; min-height:550px">
        <!-- Gardener Image Cutout -->
        <div class="gardener-wrap" style="flex:1; position:relative; height:600px; display:flex; align-items:flex-end">
          <img src="/gardener-cta.png?v=final" class="gardener-img" alt="Expert Gardener" style="position:absolute; bottom:0; left:-50px; max-width:650px; width:135%; z-index:1" />
        </div>

        <!-- Content Area -->
        <div style="flex:1">
          <div style="display:inline-flex; align-items:center; gap:0.5rem; margin-bottom:1.5rem">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#e0a526" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            <span style="color:#e0a526; font-size:0.85rem; font-weight:700; text-transform:uppercase; letter-spacing:1px">Trusted {client.name}</span>
          </div>
          <h2 style="font-size:clamp(2rem, 4vw, 3.5rem); font-weight:800; color:#fff; line-height:1.2; margin-bottom:2.5rem">
            Expert care for your <br/> home maintenance
          </h2>

          <!-- Feature Grid -->
          <div class="feature-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem 2rem; margin-bottom:3.5rem">
            {[
              "Landscape design & planning",
              "Soil health improvement",
              "Vertical and terrace gardening",
              "Tree and shrub trimming"
            ].map(feature => (
              <div style="display:flex; align-items:center; gap:0.75rem">
                <div style="background:rgba(224,165,38,0.2); width:24px; height:24px; border-radius:5px; display:flex; align-items:center; justify-content:center">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#e0a526" stroke-width="3"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
                </div>
                <span style="color:rgba(255,255,255,0.9); font-weight:500; font-size:1.05rem">{feature}</span>
              </div>
            ))}
          </div>

          <!-- CTAs -->
          <div class="cta-actions" style="display:flex; align-items:center; gap:3rem; flex-wrap:wrap">
            <a href="/contact" style="background:#e0a526; color:#fff; padding:1rem 2.5rem; border-radius:10px; font-weight:700; text-decoration:none; transition:0.3s" onmouseover="this.style.background='#c99420'" onmouseout="this.style.background='#e0a526'">
              Contact Us
            </a>
            <div style="display:flex; align-items:center; gap:1rem">
              <div style="width:48px; height:48px; background:rgba(255,255,255,0.1); border-radius:50%; display:flex; align-items:center; justify-content:center; color:#fff">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div style="display:flex; flex-direction:column">
                <span style="color:rgba(255,255,255,0.6); font-size:0.8rem">Call us (toll free)</span>
                <a href={`tel:${client.phone}`} style="color:#fff; font-weight:800; font-size:1.25rem; text-decoration:none">{client.phone}</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

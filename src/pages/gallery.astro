---
import Layout from '../layouts/Layout.astro'
import { client } from '../client.config.js'
import PageHero from '../components/PageHero.astro'
import ReadyToWork from '../components/ReadyToWork.astro'

let gallery = []
try {
  const res = await fetch(`${client.cmsUrl}/api/gallery?where[tenant.slug][equals]=${client.tenantSlug}&limit=20`)
  gallery = (await res.json()).docs || []
} catch {}

const primary = client.primaryColor || '#2d5a3d'
---

<Layout title="Gallery" description={`View our work — ${client.name} project gallery.`}>

  <PageHero 
    title="Our Work" 
    image="https://images.unsplash.com/photo-1598902108854-10e335adac99?auto=format&fit=crop&q=80&w=2000"
    breadcrumb="Gallery"
  />

  <section style="padding:4rem 1.5rem">
    <div style="max-width:1200px;margin:0 auto">
      {gallery.length > 0 ? (
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem">
          {gallery.map((item: any) => (
            <div style="border-radius:12px;overflow:hidden;border:1px solid #e5e7eb">
              {item.image?.url && <img src={item.image.url} alt={item.title || 'Project'} style="width:100%;aspect-ratio:4/3;object-fit:cover" />}
              {item.title && <div style="padding:0.75rem 1rem;font-weight:500;font-size:0.9rem">{item.title}</div>}
            </div>
          ))}
        </div>
      ) : (
        <div style="text-align:center;padding:4rem;color:#6b7280">
          <div style="font-size:4rem;margin-bottom:1rem">📸</div>
          <p style="font-size:1.1rem;font-weight:500;margin-bottom:0.5rem">Photos coming soon!</p>
          <p style="font-size:0.875rem">Check back for project photos from our team.</p>
        </div>
      )}
    </div>
  </section>

  <ReadyToWork />
</Layout>